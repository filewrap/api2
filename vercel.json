{
  "version": 2,
  "name": "streamify-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://apis.kailashhh.com/api/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://socket.apis.kailashhh.com/socket.io/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://apis.kailashhh.com/api",
    "VITE_SOCKET_URL": "https://socket.apis.kailashhh.com"
  }
}
